{
  "manifest_version": 3,
  "name": "AI Chat Sidebar",
  "version": "2.0",
  "description": "在侧边栏与 AI 对话，支持流式传输",
  "permissions": [
    "tabs",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {},
  "icons": {
    "16": "icon16.png",
    "192": "icon192.png"
  }
}